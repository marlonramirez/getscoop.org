
.search-container
    flex 0 1 500px
    margin 0 1em
    transition transform 0.2s ease

.search-form
    position relative
    display flex
    align-items center

.search-form input
    width 100%
    padding 10px 45px
    border-radius 12px
    border 1px solid #e2e8f0
    background-color #f8fafc
    font-size 14px
    transition all 0.3s ease
    outline none

.search-form input:focus
    background-color #fff
    border-color #fbbf24
    box-shadow 0 0 0 4px rgba(251, 191, 36, 0.1)
    transform scale(1.01)
    box-shadow 0 4px 20px rgba(251, 191, 36, 0.15)

.search-icon
    position absolute
    left 15px
    width 18px
    height 18px
    display flex
    align-items center

.search-shortcut
    position absolute
    right 15px
    background #fff
    border 1px solid #e2e8f0
    border-radius 4px
    padding 2px 6px
    font-size 12px
    color #94a3b8
    pointer-events none

.search-results-dropdown
    position: absolute
    top calc(100% + 5px)
    left 0
    right 0
    background white
    border-radius 12px
    box-shadow 0 10px 25px rgba(0,0,0,0.1)
    border 1px solid #e2e8f0
    z-index 1000
    max-height 400px
    overflow-y auto
    padding 10px

.result-item
    display flex
    position relative
    flex-direction column
    padding 12px 15px
    text-decoration none
    color #334155
    transition background 0.2s

.result-item:hover, .result-item.active
    background-color #f8fafc

.result-item.active:before
    visibility visible
    width 100%

.result-title
    font-weight 600
    color #1e293b
    font-size 14px

.result-preview
    font-size 12px
    color #64748b
    margin-top 4px

.no-results
    padding 20px
    text-align center
    color #94a3b8
    font-size 14px

.search-results-dropdown::-webkit-scrollbar
    width 6px

.search-results-dropdown::-webkit-scrollbar-thumb
    background #cbd5e1
    border-radius 10px
