{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "paths": {
      "@/*": ["./app/scripts/*"],
      "#/*": ["./app/styles/*"]
    }
  },
  "include": ["app/**/*"],
  "exclude": ["node_modules", "public"]
}
